# ============================================================
# Brindi - Variables de entorno (.env.example)
# ------------------------------------------------------------
# Copia este archivo a .env (scripts/setup-local.sh lo hace
# automaticamente y genera los secretos marcados como
# "__autogenerado_por_setup__").
#
# REGLAS:
#   - NUNCA subas .env al repositorio (esta en .gitignore).
#   - Sin espacios alrededor del "=" y sin comentarios en la
#     misma linea del valor (compatibilidad docker compose).
# ============================================================

# ---------- App ----------
# Nombre de la app. Constante unica de branding: si algun dia
# se renombra el producto, cambiar aqui y hacer find & replace
# del literal "brindi"/"Brindi" en el repo.
APP_NAME=Brindi
NODE_ENV=development

# ---------- PostgreSQL ----------
POSTGRES_USER=brindi
# Generado aleatoriamente por scripts/setup-local.sh
POSTGRES_PASSWORD=__autogenerado_por_setup__
POSTGRES_DB=brindi
POSTGRES_PORT=5432

# Cadena de conexion usada por la API y las herramientas de Prisma
# cuando se ejecutan FUERA de Docker (apunta a localhost).
# Dentro de Docker Compose se construye otra automaticamente
# apuntando al servicio "postgres". setup-local.sh la genera por ti.
DATABASE_URL=__autogenerado_por_setup__

# ---------- Redis (sesiones, rate limiting, cache de Places) ----------
REDIS_PORT=6379

# ---------- API (NestJS) ----------
API_PORT=4000
# Origen del frontend permitido por CORS
WEB_ORIGIN=http://localhost:3000

# ---------- Web (Next.js) ----------
WEB_PORT=3000
# URL publica de la API que usa el navegador.
# Se inyecta en el bundle del frontend en tiempo de build.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------- ai-service (FastAPI) ----------
# Puerto interno del servicio de IA (no se publica al host).
AI_PORT=5000
# Secreto compartido entre la API (NestJS) y el ai-service para las llamadas internas.
# Generado aleatoriamente por scripts/setup-local.sh
INTERNAL_API_KEY=__autogenerado_por_setup__

# ---------- Autenticacion ----------
# Secretos de firma JWT (access y refresh usan secretos distintos).
# Generados aleatoriamente por scripts/setup-local.sh
JWT_SECRET=__autogenerado_por_setup__
JWT_REFRESH_SECRET=__autogenerado_por_setup__

# ---------- Claves externas (RELLENAR MANUALMENTE) ----------
# Sin estas claves la app funciona, pero quedan deshabilitadas
# las funciones de IA (OCR de tickets, quiz IA, planes) y mapas.

# Google Gemini (OCR de tickets; mas adelante quiz y planes). Sin ella, el OCR responde 502.
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google OAuth 2.0 (login con Google).
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Places API (autocompletado y busqueda de lugares en PLAN).
# Obtener en: https://console.cloud.google.com/google/maps-apis
GOOGLE_PLACES_API_KEY=
