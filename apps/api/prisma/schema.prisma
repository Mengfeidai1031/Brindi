// ============================================================
// Brindi - Esquema de base de datos (Prisma + PostgreSQL)
// ------------------------------------------------------------
// MINIMALISTA POR DISEÑO DE PRIVACIDAD: solo 3 tablas.
// NO existen tablas para tickets, divisiones, planes ni
// ubicaciones: esos datos viven en memoria del cliente y se
// descartan (ver README, "Principio de privacidad").
// ============================================================

generator client {
  provider   = "prisma-client-js"
  // Cliente sin motores binarios Rust: query compiler (WASM, GA) +
  // driver adapter de node-postgres. Builds de Docker más rápidos y
  // sin descargas de binarios (ver "Decisiones de diseño" del README).
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// Usuarios: lo estrictamente necesario para el login.
// password_hash es opcional porque los usuarios que entren solo
// con Google OAuth no tienen contraseña local.
// payment_link es el ÚNICO dato "de pago" que se guarda, es del
// propio usuario, opcional y editable (p.ej. paypal.me/usuario).
// ------------------------------------------------------------
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?   @map("password_hash")
  name         String
  locale       String    @default("es")
  paymentLink  String?   @map("payment_link")
  googleId     String?   @unique @map("google_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("users")
}

// ------------------------------------------------------------
// Telemetría de IA: registro agregado de cada llamada a Gemini
// (servicio, modelo usado en la cascada de fallback, tokens,
// éxito/fallo). Sin contenido de prompts ni datos de usuario.
// ------------------------------------------------------------
model AiUsage {
  id        String   @id @default(uuid())
  service   AiService
  modelUsed String   @map("model_used")
  tokens    Int      @default(0)
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([service, createdAt])
  @@map("ai_usage")
}

enum AiService {
  OCR_RECEIPT
  GENERATE_QUIZ
  GENERATE_PLAN
}

// ------------------------------------------------------------
// Preguntas de fallback para el quiz de trivia: se usan cuando
// Gemini no está disponible o devuelve JSON inválido tras agotar
// la cascada, y para el modo offline de la PWA.
// Seed inicial: mínimo 10 preguntas por categoría predefinida.
// ------------------------------------------------------------
model QuizFallbackQuestion {
  id           String       @id @default(uuid())
  category     QuizCategory
  level        QuizLevel
  locale       String       @default("es")
  question     String
  optionsJson  Json         @map("options_json")
  correctIndex Int          @map("correct_index")
  explanation  String

  @@unique([category, question])
  @@index([category, level, locale])
  @@map("quiz_fallback_questions")
}

enum QuizCategory {
  FUTBOL
  PELICULAS_SERIES
  MUSICA
  GEOGRAFIA
  HISTORIA
  CIENCIA
  RANDOM
}

enum QuizLevel {
  FACIL
  MEDIO
  DIFICIL
  IMPOSIBLE
}
